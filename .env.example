# ── Saxo Bank OpenAPI — OAuth2 configuration ─────────────────────────────────
#
# Step 1: Register a free app at https://developer.saxobank.com
#         Set redirect URI to:  http://localhost:8501/
#
# Step 2: Copy Client ID + Client Secret below.
#
# Step 3: Run the app and use the "Saxo Connect" tab to authenticate.
#         Tokens are written back here automatically after login.
#
# ─────────────────────────────────────────────────────────────────────────────
# NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# App credentials (from developer.saxobank.com → My Apps)
SAXO_CLIENT_ID=
SAXO_CLIENT_SECRET=
SAXO_REDIRECT_URI=http://localhost:8501/

# "sim"  — simulation gateway (safe, no real trades, real API data)
# "live" — live gateway (real money — use with extreme caution)
SAXO_ENV=sim

# ── Written automatically after login — do not edit manually ─────────────────
SAXO_ACCESS_TOKEN=
SAXO_REFRESH_TOKEN=
SAXO_TOKEN_EXPIRY=
